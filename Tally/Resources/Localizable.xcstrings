    "Custom setup": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "自訂設定"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "自定义设置"
          }
        },
