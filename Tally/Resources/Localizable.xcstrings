    "Links the tally command into /usr/local/bin so any terminal can use it.": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "把 tally 指令連結到 /usr/local/bin，任何終端機都能使用。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
