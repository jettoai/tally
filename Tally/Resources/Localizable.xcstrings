    "Auto starts new sessions on the account with the most room; Manual uses the card you pick in the panel.": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "自動：新工作階段用餘量最多的帳號啟動；手動：用你在面板點選的帳號。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
