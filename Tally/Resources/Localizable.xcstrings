    "Auto starts new sessions on the account with the most room; Manual uses the card you pick in the panel.": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "自動：新工作階段用餘量最多的帳號啟動；手動：用你在面板點選的帳號。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "自动：新会话用余量最多的账号启动；手动：用你在面板点选的账号。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "自動：残量が最も多いアカウントで新しいセッションを開始します。手動：パネルで選んだアカウントを使用します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "자동: 여유가 가장 많은 계정으로 새 세션을 시작합니다. 수동: 패널에서 선택한 계정을 사용합니다."
          }
        }
      }
    },
