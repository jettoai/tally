          }
        }
      }
    },
    "Routes bare codex commands through your launch policy. Installs one small script and one PATH line; both are removed cleanly.": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "讓直接輸入的 codex 指令也遵循你的啟動策略。安裝一個小腳本和一行 PATH，移除時完整清除。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "让直接输入的 codex 命令也遵循你的启动策略。安装一个小脚本和一行 PATH，移除时完整清除。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "素の codex コマンドも起動ポリシーに従うようにします。小さなスクリプト 1 つと PATH 1 行を追加し、削除時は完全に元へ戻ります。"
          }
        },
        "ko": {
