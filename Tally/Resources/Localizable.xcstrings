    "Run this in a terminal and finish the login; the account appears here within a minute.": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在終端機執行並完成登入，帳號一分鐘內會自動出現在這裡。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
