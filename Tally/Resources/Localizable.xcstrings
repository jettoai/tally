    "This build has no update feed; download new versions from GitHub Releases.": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此版本未連接更新來源；新版請至 GitHub Releases 下載。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此版本未连接更新源；新版请至 GitHub Releases 下载。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このビルドはアップデートフィードに接続していません。新しいバージョンは GitHub Releases から入手してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 빌드는 업데이트 피드에 연결되어 있지 않습니다. 새 버전은 GitHub Releases에서 받으세요."
          }
        }
      }
    },
    "Move this directory's latest conversation to another account and continue there": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "把這裡最近的對話搬到另一個帳號續聊"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "把这里最近的对话搬到另一个账号继续聊"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このディレクトリの最新の会話を別のアカウントに移して続けます"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
